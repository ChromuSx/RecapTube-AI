# RecapTubeAI — environment template (safe to commit)
# Copy this file to `.env` and fill in your own keys.
# These are for local reference only; the extension reads keys from the popup
# (chrome.storage.local), not from this file.

# Anthropic Claude API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...
